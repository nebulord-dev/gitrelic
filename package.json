{
  "name": "codelore",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "codelore": "node apps/cli/dist/index.js",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:web": "pnpm --filter @codelore/web test:ui",
    "test:cli": "pnpm --filter @codelore/cli test:ui",
    "test:core": "pnpm --filter @codelore/core test:ui"
  },
  "devDependencies": {
    "turbo": "^2.8.14",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.30.1"
}
