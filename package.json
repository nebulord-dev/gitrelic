{
  "name": "gitrelic",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "docs:dev": "pnpm --filter @gitrelic/docs docs:dev",
    "docs:build": "pnpm --filter @gitrelic/docs docs:build",
    "typecheck": "turbo run typecheck",
    "gitrelic": "node apps/cli/dist/index.mjs",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:core": "vitest --ui --coverage --root packages/core",
    "test:web": "vitest --ui --coverage --root apps/web",
    "prepare": "husky",
    "all-checks": "pnpm build && pnpm test && pnpm lint && pnpm format"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@vitest/coverage-v8": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "semantic-release": "^25.0.3",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs}": [
      "oxlint --fix",
      "oxfmt"
    ],
    "**/*.{css,html,json,jsonc}": [
      "oxfmt"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "esbuild@<0.25.0": "^0.25.0",
      "vitepress>vite": "^6.4.2",
      "flatted@<3.4.2": "^3.4.2"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
