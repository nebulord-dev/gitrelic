{
  "name": "gitlore",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "gitlore": "node apps/cli/dist/index.js",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:web": "pnpm --filter @gitlore/web test:ui",
    "test:cli": "pnpm --filter @gitlore/cli test:ui",
    "test:core": "pnpm --filter @gitlore/core test:ui"
  },
  "devDependencies": {
    "turbo": "^2.8.20",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.30.1"
}
