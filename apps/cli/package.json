{
  "name": "gitrelic",
  "version": "0.36.0",
  "description": "Git archaeology CLI — surface churn, bus factor, hotspots, and cursed files from your repo's git history",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nebulord-dev/gitrelic"
  },
  "bin": {
    "gitrelic": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.5.2",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "open": "^11.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@gitrelic/core": "workspace:*",
    "@gitrelic/web": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
